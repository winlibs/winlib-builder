diff --git a/lib/util-get-random-bytes.c b/lib/util-get-random-bytes.c
index b8becd9..6d67fee 100644
--- a/lib/util-get-random-bytes.c
+++ b/lib/util-get-random-bytes.c
@@ -31,6 +31,10 @@
 #ifdef HAVE_SYS_STAT_H
 #include <sys/stat.h>
 #endif
+#ifdef _MSC_VER
+#include <Windows.h>
+#include <bcrypt.h>
+#endif
 
 /* If we have O_CLOEXEC, we use it, but if we don't, we don't worry
    about it.  */
@@ -146,6 +150,16 @@ get_random_bytes(void *buf, size_t buflen)
         }
     }
 #endif
+#ifdef _MSC_VER
+  BCRYPT_ALG_HANDLE algo;
+  if (!BCRYPT_SUCCESS(BCryptOpenAlgorithmProvider(&algo, BCRYPT_RNG_ALGORITHM, NULL, 0)))
+    return false;
+  if (!BCRYPT_SUCCESS(BCryptGenRandom(algo, buf, (ULONG) buflen, 0)))
+    return false;
+  if (!BCRYPT_SUCCESS(BCryptCloseAlgorithmProvider(algo, 0)))
+    return false;
+  return true;
+#endif
 
   /* if we get here, we're just completely hosed */
   errno = ENOSYS;
diff --git a/lib/util-xbzero.c b/lib/util-xbzero.c
index 39687fa..c7d307b 100644
--- a/lib/util-xbzero.c
+++ b/lib/util-xbzero.c
@@ -34,10 +34,16 @@
    after the memset call, declared to read the memory that the memset
    writes.  */
 
+#ifdef _MSC_VER
+# define OBSERVE_MEM(s) ((void) (s))
+#else
+# define OBSERVE_MEM(s) asm volatile ("" : : "g" (s) : "memory")
+#endif
+
 NO_INLINE void
 explicit_bzero (void *s, size_t len)
 {
   s = memset (s, 0, len);
-  asm volatile ("" : : "g" (s) : "memory");
+  OBSERVE_MEM (s);
 }
 #endif
