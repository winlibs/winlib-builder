From a3e84b63f4e53e402c048ead06e56803670a9946 Mon Sep 17 00:00:00 2001
From: Shivam Mathur <shivam_jpr@hotmail.com>
Date: Wed, 25 Mar 2026 11:53:22 +0530
Subject: [PATCH] cURL Patch

---
 CMakeLists.txt | 10 ++++++++--
 1 file changed, 8 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1eb64a9cd..70396c04a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -143,7 +143,13 @@ if(CMAKE_CROSSCOMPILING)
     "${CMAKE_SYSTEM_NAME}/${CMAKE_SYSTEM_PROCESSOR}")
 endif()
 
-if(CMAKE_C_COMPILER_TARGET)
+if(WIN32)
+  if(CMAKE_SIZEOF_VOID_P EQUAL 8)
+    set(CURL_OS "\"x86_64-pc-win32\"")
+  else()
+    set(CURL_OS "\"i386-pc-win32\"")
+  endif()
+elseif(CMAKE_C_COMPILER_TARGET)
   set(CURL_OS "\"${CMAKE_C_COMPILER_TARGET}\"")
 else()
   set(CURL_OS "\"${CMAKE_SYSTEM_NAME}\"")
@@ -153,7 +159,7 @@ if(CURL_PATCHSTAMP)
   set(CURL_PATCHSTAMP "\"${CURL_PATCHSTAMP}\"")
 endif()
 
-set(LIB_NAME "libcurl")
+set(LIB_NAME "libcurl_a")
 set(EXE_NAME "curl")
 
 set_property(DIRECTORY APPEND PROPERTY INCLUDE_DIRECTORIES "${PROJECT_SOURCE_DIR}/include")
-- 
